#!/usr/bin/env bash
set -euo pipefail

# new-project — scaffold a new product from the template, then launch the bootstrap interview.
#
# Usage:  new-project <name> [--dir <parent>] [--no-launch]
#
# Deterministic steps only (no judgment). See the design spec:
#   docs/superpowers/specs/2026-06-21-new-project-bootstrapper-design.md

# Resolve this script's real location, following symlinks (so a `new-project`
# symlink placed on PATH still finds the repo's template/ and skill).
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [ "${SOURCE#/}" = "$SOURCE" ] && SOURCE="$DIR/$SOURCE"  # relative symlink
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
TEMPLATE_DIR="$ROOT_DIR/template"
SKILL_SRC="$ROOT_DIR/.claude/skills/project-bootstrap"

usage() {
  cat >&2 <<'EOF'
Usage: new-project <name> [--dir <parent>] [--model <name>] [--no-launch]

  <name>          Name (and directory) of the new project.
  --dir <parent>  Parent directory to create it in (default: current dir).
  --model <name>  Model to launch Claude with (e.g. opus, sonnet). Skips the
                  model picker. Omit to be asked interactively.
  --no-launch     Scaffold only; do not launch Claude.
EOF
}
die() { echo "new-project: $*" >&2; exit 1; }

# --- parse args ---
NAME=""
PARENT="$PWD"
LAUNCH=1
MODEL=""
while [ $# -gt 0 ]; do
  case "$1" in
    --dir) shift; [ $# -gt 0 ] || { usage; exit 2; }; PARENT="$1" ;;
    --model) shift; [ $# -gt 0 ] || { usage; exit 2; }; MODEL="$1" ;;
    --no-launch) LAUNCH=0 ;;
    -h|--help) usage; exit 0 ;;
    -*) usage; exit 2 ;;
    *) [ -z "$NAME" ] || { usage; exit 2; }; NAME="$1" ;;
  esac
  shift
done
[ -n "$NAME" ] || { usage; exit 2; }

[ -d "$TEMPLATE_DIR" ] || die "template payload not found at $TEMPLATE_DIR"

TARGET="$PARENT/$NAME"
[ -e "$TARGET" ] && die "target already exists: $TARGET"

# 1. copy payload
mkdir -p "$TARGET"
cp -R "$TEMPLATE_DIR"/. "$TARGET"/

# 2. make scripts + hooks executable
chmod +x "$TARGET"/scripts/*.sh 2>/dev/null || true
chmod +x "$TARGET"/.claude/hooks/*.sh 2>/dev/null || true

# 3. git init + initial commit (pristine template)
git -C "$TARGET" init -q
git -C "$TARGET" add -A
git -C "$TARGET" \
  -c user.name="${GIT_AUTHOR_NAME:-$(git config user.name 2>/dev/null || echo create-claude-product)}" \
  -c user.email="${GIT_AUTHOR_EMAIL:-$(git config user.email 2>/dev/null || echo noreply@example.com)}" \
  commit -qm "chore: scaffold from template"

# 4. seed local settings from the example
if [ -f "$TARGET/.claude/settings.local.example.json" ]; then
  cp "$TARGET/.claude/settings.local.example.json" "$TARGET/.claude/settings.local.json"
fi

# 5. inject the transient bootstrap skill
[ -d "$SKILL_SRC" ] || die "bootstrap skill not found at $SKILL_SRC"
mkdir -p "$TARGET/.claude/skills/project-bootstrap"
cp -R "$SKILL_SRC"/. "$TARGET/.claude/skills/project-bootstrap"/

# 6. write the sentinel
mkdir -p "$TARGET/.bootstrap"
created="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
cat > "$TARGET/.bootstrap/state.json" <<EOF
{
  "phase": 1,
  "name": "$NAME",
  "created": "$created"
}
EOF

# 7. launch the interview, or hand off
PROMPT="A new project was just scaffolded from the template. A .bootstrap/state.json sentinel is present — run the project-bootstrap interview to take it from here."

if [ "$LAUNCH" -eq 1 ] && command -v claude >/dev/null 2>&1; then
  cd "$TARGET"

  # Colors — only when writing to a real terminal and NO_COLOR is unset.
  if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
    B=$'\033[1m'; D=$'\033[2m'; C=$'\033[36m'; G=$'\033[32m'; R=$'\033[0m'
  else
    B=""; D=""; C=""; G=""; R=""
  fi

  # Orientation — tell the user what's about to happen before Claude takes over.
  cat <<EOF

  ${G}✓${R} ${B}Scaffolded${R} ${D}$TARGET${R}

  ${B}Claude will guide you through setup, one question at a time:${R}

      ${C}1${R}  Product               ${D}what you're building, for whom, the constraints${R}
      ${C}2${R}  Architecture & stack  ${D}pick your tech; get a runnable skeleton${R}
      ${C}3${R}  First spec            ${D}seed your first feature, ready to implement${R}

  ${D}Commits after each step — stop anytime, resume with 'claude' in this folder.${R}
EOF

  # Model picker — interactive only; honor an explicit --model and skip if piped.
  if [ -z "$MODEL" ] && [ -t 0 ]; then
    if command -v gum >/dev/null 2>&1; then
      pick="$(gum choose --header "Which model should run the interview?" \
        "Opus    — most capable, best for design decisions (recommended)" \
        "Sonnet  — faster and lighter" \
        "Default — your Claude Code default")" || pick="Opus"
      case "$pick" in
        Sonnet*)  MODEL="sonnet" ;;
        Default*) MODEL="" ;;
        *)        MODEL="opus" ;;
      esac
    else
      cat <<EOF

  ${B}Which model should run the interview?${R}

      ${C}1${R}  Opus     ${D}most capable, best for design decisions  (recommended)${R}
      ${C}2${R}  Sonnet   ${D}faster and lighter${R}
      ${C}3${R}  Default  ${D}your Claude Code default${R}
EOF
      printf "\n  ${B}Choice [1]:${R} "
      read -r reply || reply=""
      case "$reply" in
        2) MODEL="sonnet" ;;
        3) MODEL="" ;;
        *) MODEL="opus" ;;
      esac
    fi
  fi

  echo
  if [ -n "$MODEL" ]; then
    echo "  ${D}Launching Claude (model: $MODEL)…${R}"
    exec claude --model "$MODEL" "$PROMPT"
  fi
  echo "  ${D}Launching Claude…${R}"
  exec claude "$PROMPT"
fi

echo "Scaffolded $TARGET"
echo "Next: cd \"$TARGET\" && claude \"$PROMPT\""
